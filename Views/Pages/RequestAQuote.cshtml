@model CarSales.Web.ViewModels.RequestAQuotePageViewModel

@{
    ViewData["Title"] = "Yêu cầu báo giá";
    var hasCars = Model.Cars.Any();
    var selectedThumbnail = string.IsNullOrWhiteSpace(Model.SelectedCar?.Thumbnail) ? "/uploads/img/car.png" : Model.SelectedCar.Thumbnail;
}

<section class="cars-page-section">
    <div class="container">
        <div class="cars-page-header">
            <h1>Yêu cầu báo giá</h1>
            <p>Chọn mẫu xe để tạo ticket báo giá nhanh theo nhu cầu của bạn.</p>
        </div>

        @if (!hasCars)
        {
            <div class="buy-ticket-card">
                <p class="m-0">Hiện chưa có xe khả dụng để gửi yêu cầu báo giá.</p>
            </div>
        }
        else
        {
            <div class="buy-ticket-grid">
                <article class="buy-ticket-card">
                    <h3>Chọn mẫu xe</h3>
                    <p>Chọn xe từ danh sách để xem thông tin cơ bản trước khi gửi yêu cầu.</p>

                    <div class="buy-ticket-form">
                        <label class="form-label" for="quoteCarSelect">Mẫu xe</label>
                        <select id="quoteCarSelect" class="form-select">
                            @foreach (var car in Model.Cars)
                            {
                                <option value="@car.CarId"
                                        data-name="@car.CarName"
                                        data-price="@car.Price"
                                        data-thumbnail="@(string.IsNullOrWhiteSpace(car.Thumbnail) ? "/uploads/img/car.png" : car.Thumbnail)"
                                        selected="@(car.CarId == Model.SelectedCarId ? "selected" : null)">
                                    @car.CarName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="border rounded p-3 mt-3 d-flex align-items-center gap-3">
                        <img id="quoteCarThumb" src="@selectedThumbnail" alt="@Model.SelectedCar?.CarName" style="width: 88px; height: 58px; object-fit: cover; border-radius: 8px;" />
                        <div>
                            <div id="quoteCarName" class="fw-semibold">@Model.SelectedCar?.CarName</div>
                            <small id="quoteCarPrice" class="text-primary">Giá từ @(Model.SelectedCar?.Price.ToString("N0")) VNĐ</small>
                        </div>
                    </div>
                </article>

                <article class="buy-ticket-card">
                    <h3>Tạo ticket báo giá</h3>
                    <p>Gửi ticket để nhân viên UTC Car liên hệ tư vấn và báo giá chi tiết.</p>

                    @if (Model.HasOpenPurchaseRequest)
                    {
                        <p class="buy-ticket-note">Bạn đang có yêu cầu đang xử lý cho mẫu xe đã chọn.</p>
                    }

                    <form asp-controller="Cars" asp-action="CreatePurchaseRequestTicket" method="post" class="buy-ticket-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="quoteSelectedCarId" name="id" value="@Model.SelectedCarId" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <label class="form-label" for="quoteMessage">Ghi chú thêm (tuỳ chọn)</label>
                        <textarea id="quoteMessage" name="message" class="form-control" rows="3" placeholder="Ví dụ: Tôi muốn nhận báo giá lăn bánh tại Hà Nội..."></textarea>
                        <button type="submit" class="btn buy-ticket-btn">Tạo ticket yêu cầu báo giá</button>
                    </form>
                </article>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const select = document.getElementById('quoteCarSelect');
            if (!select) {
                return;
            }

            const hiddenCarId = document.getElementById('quoteSelectedCarId');
            const thumb = document.getElementById('quoteCarThumb');
            const name = document.getElementById('quoteCarName');
            const price = document.getElementById('quoteCarPrice');
            const moneyFormatter = new Intl.NumberFormat('vi-VN');

            function refreshSelectedCar() {
                const option = select.options[select.selectedIndex];
                if (!option) {
                    return;
                }

                const selectedId = option.value;
                const selectedName = option.dataset.name || '';
                const selectedThumbnail = option.dataset.thumbnail || '/uploads/img/car.png';
                const selectedPrice = Number(option.dataset.price || 0);

                if (hiddenCarId) {
                    hiddenCarId.value = selectedId;
                }

                if (thumb) {
                    thumb.src = selectedThumbnail;
                    thumb.alt = selectedName;
                }

                if (name) {
                    name.textContent = selectedName;
                }

                if (price) {
                    price.textContent = `Giá từ ${moneyFormatter.format(selectedPrice)} VNĐ`;
                }
            }

            select.addEventListener('change', refreshSelectedCar);
            refreshSelectedCar();
        });
    </script>
}
