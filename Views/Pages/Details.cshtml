@model CarSales.Web.ViewModels.ContentPageViewModel

@{
    ViewData["Title"] = Model.Title;
    var themeClass = Model.Slug switch
    {
        "online-deposit" => "content-theme-online-deposit",
        "available-cars" => "content-theme-available-cars",
        "build-and-price" => "content-theme-build-and-price",
        "price-list" => "content-theme-price-list",
        _ => string.Empty
    };

    var blockLayoutClass = Model.Slug switch
    {
        "online-deposit" => "content-blocks-timeline",
        "available-cars" => "content-blocks-checklist",
        "build-and-price" => "content-blocks-steps",
        "price-list" => "content-blocks-pricelist",
        _ => string.Empty
    };
}

<section class="content-page-section @themeClass">
    <div class="container">
        <div class="content-page-wrap">
            <p class="content-page-kicker">UTC CAR</p>
            <h1 class="content-page-title">@Model.Title</h1>
            <p class="content-page-intro">@Model.Intro</p>
            <p class="content-page-description">@Model.Description</p>

            @if (Model.Highlights.Any())
            {
                <ul class="content-page-highlights content-highlights-grid">
                    @foreach (var item in Model.Highlights)
                    {
                        <li class="content-highlight-item">@item</li>
                    }
                </ul>
            }

            @if (Model.ContentBlocks.Any())
            {
                <div class="content-page-blocks @blockLayoutClass">
                    @for (var i = 0; i < Model.ContentBlocks.Count; i++)
                    {
                        var block = Model.ContentBlocks[i];
                        <article class="content-block-card">
                            <span class="content-block-index">@(i + 1)</span>
                            <h2 class="content-block-title">@block.Heading</h2>
                            <p class="content-block-description">@block.Description</p>

                            @if (block.Items.Any())
                            {
                                <ul class="content-block-list">
                                    @foreach (var point in block.Items)
                                    {
                                        var separatorIndex = point.IndexOf(':');
                                        var hasLink = false;
                                        var linkLabel = string.Empty;
                                        var linkUrl = string.Empty;

                                        if (separatorIndex > 0)
                                        {
                                            var possibleUrl = point[(separatorIndex + 1)..].Trim();
                                            if (Uri.TryCreate(possibleUrl, UriKind.Absolute, out var uri)
                                                && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps))
                                            {
                                                hasLink = true;
                                                linkLabel = point[..separatorIndex].Trim();
                                                linkUrl = possibleUrl;
                                            }
                                        }

                                        <li>
                                            @if (hasLink)
                                            {
                                                <span>@linkLabel: </span><a href="@linkUrl" target="_blank" rel="noopener noreferrer">@linkUrl</a>
                                            }
                                            else
                                            {
                                                @point
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                        </article>
                    }
                </div>
            }

            <div class="content-page-actions">
                <a class="content-page-btn primary" href="@Model.PrimaryButtonUrl">@Model.PrimaryButtonText</a>
                <a class="content-page-btn secondary" href="@Model.SecondaryButtonUrl">@Model.SecondaryButtonText</a>
            </div>
        </div>
    </div>
</section>
