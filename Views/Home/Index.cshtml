<button type="button" class="scroll-top-btn" id="scrollTopBtn" aria-label="Lên đầu trang">
    ↑
</button>


@section Scripts {
    @{await Html.PartialAsync("_ValidationScriptsPartial");}
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('[data-car-type-link]');
            const grid = document.querySelector('[data-car-home-grid]');
            const section = document.getElementById('car-explore-section');
            const scrollTopBtn = document.getElementById('scrollTopBtn');
            let upwardAttempts = 0;
            let upwardAttemptTimeout;
            let touchStartY = 0;

            if (scrollTopBtn) {
                function registerUpwardAttempt() {
                    upwardAttempts += 1;

                    if (upwardAttemptTimeout) {
                        clearTimeout(upwardAttemptTimeout);
                    }

                    upwardAttemptTimeout = setTimeout(function () {
                        upwardAttempts = 0;
                    }, 900);

                    if (upwardAttempts >= 2 && window.scrollY > 200) {
                        scrollTopBtn.classList.add('is-visible');
                        upwardAttempts = 0;
                    }
                }

                window.addEventListener('wheel', function (event) {
                    if (event.deltaY < 0) {
                        registerUpwardAttempt();
                    } else {
                        upwardAttempts = 0;
                    }
                }, { passive: true });

                window.addEventListener('touchstart', function (event) {
                    if (event.touches.length) {
                        touchStartY = event.touches[0].clientY;
                    }
                }, { passive: true });

                window.addEventListener('touchmove', function (event) {
                    if (!event.touches.length) {
                        return;
                    }

                    const currentY = event.touches[0].clientY;
                    if (currentY > touchStartY + 12) {
                        registerUpwardAttempt();
                    }
                    touchStartY = currentY;
                }, { passive: true });

                window.addEventListener('scroll', function () {
                    if (window.scrollY < 120) {
                        scrollTopBtn.classList.remove('is-visible');
                    }
                }, { passive: true });

                scrollTopBtn.addEventListener('click', function () {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    scrollTopBtn.classList.remove('is-visible');
                });
            }

            if (!tabs.length || !grid || !section) {
                return;
            }

            tabs.forEach(function (tab) {
                tab.addEventListener('click', async function (event) {
                    event.preventDefault();

                    tabs.forEach(function (item) {
                        item.classList.remove('is-active');
                    });
                    tab.classList.add('is-active');

                    const url = tab.dataset.url;
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!response.ok) {
                        return;
                    }

                    grid.innerHTML = await response.text();
                    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });
        });

        // Custom jQuery validation method
        $.validator.addMethod('phonevu', function (value, element) {
            return this.optional(element) || /^(0[35789]|09)\d{8}$/.test(value);
        }, 'Vui lòng nhập số điện thoại hợp lệ');

        // Apply validation rules when the form is submitted
        $('form').submit(function () {
            $(this).validate();
        });
    </script>
}