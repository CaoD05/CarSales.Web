@model CarSales.Web.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
    var heroCars = Model.HeroCars ?? new List<CarSales.Web.Models.Car>();

    var heroItems = new[]
    {
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776355413/13335504_1280_720_24fps_qwu64i.mp4", Title = "Porsche", Subtitle = "911 Carrera 4S" },
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776355414/13684270_1280_720_24fps_zg8wup.mp4", Title = "Ferrari", Subtitle = "296 GTB" },
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776355413/13171245_1280_720_60fps_nv3rr5.mp4", Title = "Ferrari", Subtitle = "488 GTB" },
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776355413/13103344_1280_720_60fps_ckn1fj.mp4", Title = "BMW", Subtitle = "E92 M3" },
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776357514/13796124-hd_1280_720_24fps_yew7pk.mp4", Title = "Nissan", Subtitle = "350Z" },
        new { Video = "https://res.cloudinary.com/du6xqz29n/video/upload/q_auto/f_auto/v1776468622/4632304-hd_1280_720_25fps_ky5d4d.mp4", Title = "Lamborghini", Subtitle = "Huracan" },
    };

    string NormalizeValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();
    }

    var selectedCarTypeId = Model.SelectedCarTypeId;
}

<section class="hero hero-slider" data-hero-slider>
    <div class="hero-slider-track" aria-hidden="true">
        @for (var i = 0; i < heroItems.Length; i++)
            {
                var normalizedHeroTitle = NormalizeValue(heroItems[i].Title);
                var normalizedHeroSubtitle = NormalizeValue(heroItems[i].Subtitle);
                var heroCar =
                    heroCars.FirstOrDefault(x =>
                        !string.IsNullOrWhiteSpace(x.CarName) &&
                        x.CarName.Contains(heroItems[i].Subtitle, StringComparison.OrdinalIgnoreCase))
                    ?? heroCars.FirstOrDefault(x =>
                        !string.IsNullOrWhiteSpace(x.CarName) &&
                        (NormalizeValue(x.CarName).Contains(normalizedHeroSubtitle, StringComparison.Ordinal) ||
                         normalizedHeroSubtitle.Contains(NormalizeValue(x.CarName), StringComparison.Ordinal)))
                    ?? heroCars.FirstOrDefault(x =>
                        x.Brand != null &&
                        x.Brand.BrandName.Equals(heroItems[i].Title, StringComparison.OrdinalIgnoreCase) &&
                        !string.IsNullOrWhiteSpace(x.CarName) &&
                        x.CarName.Contains(heroItems[i].Subtitle, StringComparison.OrdinalIgnoreCase))
                    ?? heroCars.FirstOrDefault(x =>
                        x.Brand != null &&
                        NormalizeValue(x.Brand.BrandName) == normalizedHeroTitle);
                <div class="hero-slide @(i == 0 ? "is-active" : string.Empty)" data-hero-slide>
                    <video class="hero-video" autoplay muted loop playsinline preload="metadata">
                        <source src="@heroItems[i].Video" type="video/mp4" />
                    </video>
                    <div class="hero-text-overlay">
                        <h2 class="hero-title">@heroItems[i].Title</h2>
                        <p class="hero-subtitle">@heroItems[i].Subtitle</p>
                        @if (heroCar != null)
                        {
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@heroCar.CarId" class="btn hero-btn">Tìm hiểu thêm</a>
                        }
                        else
                        {
                            <a asp-controller="Cars" asp-action="Index" class="btn hero-btn">Tìm hiểu thêm</a>
                        }
                    </div>
                </div>
            }
    </div>

    <div class="hero-video-overlay" aria-hidden="true"></div>

    <button class="hero-nav hero-nav-prev" type="button" aria-label="Previous hero" data-hero-prev>
        <span aria-hidden="true">&#10094;</span>
    </button>
    <button class="hero-nav hero-nav-next" type="button" aria-label="Next hero" data-hero-next>
        <span aria-hidden="true">&#10095;</span>
    </button>

    <div class="hero-content">
    </div>
</section>

<div class="cmp-kba">
    <div class="kba-units">
        <a class="kba-unit" asp-controller="Pages" asp-action="Details" asp-route-slug="build-and-price">
            <img src="/uploads/img/car.png" alt="" class="kba-icon">
            <span class="kba-text">Chọn xe &amp; Báo giá</span>
            <span class="kba-arrow">&#10095;</span>
        </a>
        <a class="kba-unit" asp-controller="Pages" asp-action="Details" asp-route-slug="test-drive">
            <img src="/uploads/img/wheel.png" alt="" class="kba-icon">
            <span class="kba-text">Lái thử</span>
            <span class="kba-arrow">&#10095;</span>
        </a>
        <a class="kba-unit" asp-controller="Pages" asp-action="Details" asp-route-slug="request-a-quote">
            <img src="/uploads/img/car-loan.png" alt="" class="kba-icon">
            <span class="kba-text">Báo giá</span>
            <span class="kba-arrow">&#10095;</span>
        </a>
    </div>
</div>

<section class="discover-section">
    <div class="container">
        <div class="discover-header">
            <p class="discover-kicker">DISCOVER</p>
            <h2 class="discover-title">Xe mới về showroom</h2>
        </div>

        <div class="discover-grid">
            @if (Model.DiscoverCars.Any())
            {
                foreach (var car in Model.DiscoverCars)
                {
                    var thumb = string.IsNullOrWhiteSpace(car.Thumbnail) ? "/uploads/img/car.png" : car.Thumbnail;
                    <article class="discover-card">
                        <a class="discover-image-link" asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarId">
                            <img src="@thumb" alt="@car.CarName" class="discover-image" loading="eager" decoding="async" fetchpriority="high" />
                        </a>
                        <div class="discover-card-body">
                            <h3 class="discover-name">
                                <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarId">@car.CarName</a>
                            </h3>
                            <p class="discover-price">Chỉ từ @string.Format("{0:N0}", car.Price) VNĐ</p>
                            <a class="btn discover-btn" asp-controller="Cars" asp-action="Details" asp-route-id="@car.CarId">Khám phá</a>
                        </div>
                    </article>
                }
            }
            else
            {
                <div class="discover-empty">Hiện chưa có xe mới để khám phá.</div>
            }
        </div>
    </div>
</section>

<section class="car-explore-section" id="car-explore-section">
    <div class="container">
        <h2 class="car-explore-title">KHÁM PHÁ CÁC DÒNG XE</h2>

        <div class="car-type-tabs">
            @foreach (var carType in Model.CarTypes)
            {
                <a href="#"
                   data-url="@Url.Action("GetCarsByType", "Home", new { carTypeId = carType.CarTypeId })"
                   class="car-type-tab @(selectedCarTypeId == carType.CarTypeId ? "is-active" : string.Empty)"
                   data-car-type-link>
                    @carType.TypeName.ToUpper()
                </a>
            }
        </div>

        <div class="car-home-grid" data-car-home-grid>
            @await Html.PartialAsync("_CarExploreGrid", Model.Cars)
        </div>
    </div>
</section>


<section class="features">
    <div class="container">
        <h2 class="section-title">Tại Sao UTC Car Là Địa Chỉ Đáng Tin Cậy?</h2>
        <div class="grid-4">
            <div class="feature-item">
                <h3>Pháp lý rõ ràng</h3>
                <p>Cam kết xe cung cấp tới khách hàng đều có đầy đủ hồ sơ pháp lý rõ ràng, sang tên nhanh gọn.</p>
            </div>
            <div class="feature-item">
                <h3>Kiểm định khắt khe</h3>
                <p>Toàn bộ xe nhập về showroom đều được kiểm định bởi chuyên gia hơn 10 năm kinh nghiệm.</p>
            </div>
            <div class="feature-item">
                <h3>Giao xe toàn quốc</h3>
                <p>Hỗ trợ xem xe và giao xe tận nơi trên toàn quốc bởi đội ngũ nhân viên UTC Car.</p>
            </div>
            <div class="feature-item">
                <h3>Trả góp lên tới 70%</h3>
                <p>Sở hữu xe chỉ từ 30% giá trị với thủ tục trả góp ngân hàng nhanh chóng.</p>
            </div>
        </div>
    </div>
</section>

@if (Model.IsLoggedIn)
{
    <section class="favorite-section">
        <div class="container">
            <h2 class="section-title">Xe yêu thích của bạn</h2>
            @if (Model.FavoriteCars.Any())
            {
                <div class="favorite-grid">
                    @foreach (var favoriteCar in Model.FavoriteCars)
                    {
                        var favoriteThumb = string.IsNullOrWhiteSpace(favoriteCar.Thumbnail) ? "/uploads/img/car.png" : favoriteCar.Thumbnail;
                        <article class="favorite-card">
                            <a asp-controller="Cars" asp-action="Details" asp-route-id="@favoriteCar.CarId">
                                <img src="@favoriteThumb" alt="@favoriteCar.CarName" class="favorite-card-image" />
                            </a>
                            <div class="favorite-card-body">
                                <h3>
                                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@favoriteCar.CarId">@favoriteCar.CarName</a>
                                </h3>
                                <p>@favoriteCar.Brand?.BrandName · @favoriteCar.CarType?.TypeName</p>
                                <p class="favorite-card-price">@favoriteCar.Price.ToString("N0") VNĐ</p>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="favorite-empty">Bạn chưa có xe yêu thích nào.</div>
            }
        </div>
    </section>
}


