@model CarSales.Web.Models.Car

@{
    ViewData["Title"] = "Sửa xe";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="m-0" style="color: #0f2f7a; font-weight: 600;">Cập nhật xe</h2>
    <a asp-area="Admin" asp-controller="CarsManagement" asp-action="Index" class="dashboard-btn">Quay lại danh sách</a>
</div>

<div class="dashboard-panel p-4">
    <form asp-area="Admin" asp-controller="CarsManagement" asp-action="Edit" method="post" enctype="multipart/form-data">
        <input asp-for="CarId" type="hidden" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="CarName" class="form-label">Tên xe</label>
                <input asp-for="CarName" class="form-control" />
                <span asp-validation-for="CarName" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="BrandId" class="form-label">Hãng</label>
                <select asp-for="BrandId" asp-items="ViewBag.BrandId" class="form-select"></select>
                <span asp-validation-for="BrandId" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="CarTypeId" class="form-label">Loại xe</label>
                <select asp-for="CarTypeId" asp-items="ViewBag.CarTypeId" class="form-select"></select>
                <span asp-validation-for="CarTypeId" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Price" class="form-label">Giá</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Year" class="form-label">Năm</label>
                <input asp-for="Year" class="form-control" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Mileage" class="form-label">Số km</label>
                <input asp-for="Mileage" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="FuelType" class="form-label">Nhiên liệu</label>
                <input asp-for="FuelType" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Transmission" class="form-label">Hộp số</label>
                <input asp-for="Transmission" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Seats" class="form-label">Số chỗ</label>
                <input asp-for="Seats" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Color" class="form-label">Màu sắc</label>
                <input asp-for="Color" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Engine" class="form-label">Động cơ</label>
                <input asp-for="Engine" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Origin" class="form-label">Xuất xứ</label>
                <input asp-for="Origin" class="form-control" />
            </div>

            <div class="col-md-4">
                <label asp-for="Status" class="form-label">Trạng thái</label>
                <select asp-for="Status" class="form-select">
                    <option value="Available">Available</option>
                    <option value="Reserved">Reserved</option>
                    <option value="Sold">Sold</option>
                    <option value="Hidden">Hidden</option>
                </select>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label">Mô tả</label>
                <textarea asp-for="Description" rows="5" class="form-control"></textarea>
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsFeatured" class="form-check-input" />
                    <label asp-for="IsFeatured" class="form-check-label">Xe nổi bật</label>
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label d-block">Ảnh hiện tại</label>
                @if (!string.IsNullOrEmpty(Model.Thumbnail))
                {
                    <img src="@Model.Thumbnail" alt="@Model.CarName" class="img-thumbnail" style="width: 200px; height: 130px; object-fit: cover;" />
                }
                else
                {
                    <span class="text-muted">Chưa có ảnh đại diện.</span>
                }
            </div>

            <div class="col-md-6">
                <label class="form-label">Chọn ảnh mới</label>
                <input type="file" name="upload" class="form-control" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="dashboard-btn primary">Cập nhật</button>
            <a asp-area="Admin" asp-controller="CarsManagement" asp-action="Index" class="dashboard-btn">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}